# SportsHub Environment Variables
# Managed via 1Password Developer Environments (Espey Family vault)
# Configure at: 1Password Desktop → Developer → Environments → SportsHub → Destinations
# Set destination path to: /Users/bradyespey/Projects/SportsHub/.env

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
